# Required — S3 storage credentials
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Optional — S3 settings
# S3_ROOT=upgrade_test_data
# S3_ENDPOINT_URL=

# Optional — version overrides
# INITIAL_META_VERSION=1.2.307
# INTERMEDIATE_META_VERSION=1.2.768
# TARGET_META_VERSION=1.2.879
# OLD_QUERY_VERSION=1.2.636
# NEW_QUERY_VERSION=1.2.887

# Optional — download mirror
# DOWNLOAD_BASE_URL=https://repo.databend.com/databend/yf

# Optional — work directory
# WORK_DIR=./work

# Optional — skip dangerous permission tests
# SKIP_DANGEROUS_PERM_TESTS=1

# Distributed mode (optional)
# DEPLOY_MODE=distributed
# META_HOSTS=10.0.1.1,10.0.1.2,10.0.1.3
# QUERY_HOSTS=10.0.2.1,10.0.2.2,10.0.2.3
# SSH_USER=ubuntu
# SSH_KEY=
# REMOTE_WORK_DIR=
